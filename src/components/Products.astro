<section class="pt-20 lg:pt-28 pb-32 px-6 md:px-12 bg-gray-50/50 border-t border-gray-100">
  <div class="max-w-7xl mx-auto">
    <div class="flex flex-col md:flex-row justify-between items-end mb-20 gap-12">
      <div class="max-w-2xl">
        <div class="flex items-center gap-3 mb-8">
          <div class="w-8 h-[2px] bg-[#FF0000]" />
          <span class="text-[11px] font-bold tracking-[0.25em] uppercase text-[#FF0000]">
            Global Distribution
          </span>
        </div>
        <h2 class="text-5xl lg:text-[72px] font-black tracking-tight text-general-black leading-[0.95]">
          Featured <br />
          <span class="text-[#FF0000] italic font-medium">Products.</span>
        </h2>
      </div>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-12">
      
      <a href="#" class="group relative block rounded-3xl overflow-hidden border border-gray-100 transition-all duration-700 hover:shadow-2xl hover:-translate-y-2 bg-[#9B4019]">
        <img src="/mitutoyoproduct.png" alt="Mitutoyo Products" class="w-full h-auto object-contain transition-transform duration-1000 group-hover:scale-105" />
      </a>

      <a href="#" class="group relative block rounded-3xl overflow-hidden border border-gray-100 transition-all duration-700 hover:shadow-2xl hover:-translate-y-2 bg-gray-50">
        <img src="/pneumaticproduct.png" alt="Pneumatic Tools" class="w-full h-full object-cover transition-transform duration-1000 group-hover:scale-105" />
      </a>

      <a href="#" class="group relative block rounded-3xl overflow-hidden border border-gray-100 transition-all duration-700 hover:shadow-2xl hover:-translate-y-2 bg-gray-950">
        <img src="/norbarproduct.png" alt="Norbar Torque" class="w-full h-full object-cover transition-transform duration-1000 group-hover:scale-105" />
      </a>

    </div>
  </div>
</section>
