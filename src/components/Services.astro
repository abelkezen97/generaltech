---
const services = [
  { name: "PRV Testing Services", image: "/pvrtesting.png" },
  { name: "VFD Repair", image: "/vfdrepair.png" },
  { name: "CMM Calibration", image: "/cmmcalibration.png" },
  { name: "VFD and Starter Panel Customization", image: "/vfdandstarterpanel.png" },
  { name: "Thermal Imaging", image: "/thermalimaging.png" },
  { name: "Automation Services", image: "/automation.png" },
  { name: "Servo Motor Repair", image: "/servomotorrepair.png" },
  { name: "Live Panel Cleaning", image: "/livepanelcleaning.png" },
  { name: "Air Leakage Survey", image: "/airleakagesurvey.png" },
  { name: "Custom Tool Boxes", image: "/customtoolboxes.png" },
  { name: "Laser Marking", image: "/lasermarking.png" },
  { name: "CMM Retrofits", image: "/cmmretrofit.png" }
];
---

<section class="pt-20 lg:pt-32 pb-32 lg:pb-48 bg-white relative border-t border-gray-100 overflow-hidden" id="services-section">
  <div class="max-w-7xl mx-auto px-6 md:px-12 relative z-10 mb-20">
    <div class="flex flex-col md:flex-row justify-between items-end gap-12">
      <div class="max-w-2xl opacity-0 translate-y-8 reveal-services">
        <div class="flex items-center gap-3 mb-8">
          <div class="w-8 h-[2px] bg-[#FF0000]"></div>
          <span class="text-[11px] font-bold tracking-[0.25em] uppercase text-[#FF0000]">Engineering Solutions</span>
        </div>
        <h2 class="text-5xl lg:text-[72px] font-black tracking-tight text-gray-950 leading-[0.95]">
          Comprehensive <br />
          <span class="text-[#FF0000] italic font-medium">Services.</span>
        </h2>
      </div>
      <div class="flex-1 max-w-xl opacity-0 translate-y-8 reveal-services">
        <p class="text-gray-500 font-light text-xl leading-relaxed border-l-2 border-[#FF0000]/10 pl-8">
          Beyond calibration, we provide world-class repair, retrofit, and specialized engineering automation services designed for maximum operational efficiency.
        </p>
      </div>
    </div>
  </div>

  <div class="max-w-7xl mx-auto px-6 md:px-12 relative z-10">
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
      {services.map((service, index) => (
        <a href="#" class="group relative h-[400px] rounded-2xl overflow-hidden bg-gray-100 flex flex-col justify-end p-10 border border-gray-100 transition-all duration-500 hover:shadow-2xl hover:-translate-y-2 opacity-0 translate-y-8 reveal-services" style={`transition-delay: ${index * 50}ms`}>
          <div class="absolute inset-0 z-0">
            <img src={service.image} alt={service.name} class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-110" loading="lazy" />
            <div class="absolute inset-0 bg-gradient-to-t from-black via-black/40 to-transparent opacity-70 group-hover:opacity-85 transition-opacity duration-500"></div>
          </div>
          <div class="relative z-10 w-full">
            <div class="w-12 h-[2px] bg-[#FF0000] mb-6 group-hover:w-full transition-all duration-700 origin-left"></div>
            <h3 class="text-2xl lg:text-[26px] font-bold text-white tracking-tight leading-[1.1] mb-3 transition-colors duration-300">
              {service.name}
            </h3>
          </div>
        </a>
      ))}
    </div>
  </div>
  
  <div class="flex justify-center pt-20 relative z-10 opacity-0 translate-y-8 reveal-services">
    <a href="#" class="inline-flex items-center justify-center px-12 py-5 bg-gray-950 text-white rounded-xl text-sm font-bold tracking-wide hover:bg-[#FF0000] transition-all duration-400 shadow-2xl">
      Request Technical Service
    </a>
  </div>
</section>

<script>
  const observer = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
      if (entry.isIntersecting) {
        entry.target.classList.remove('opacity-0', 'translate-y-8');
        entry.target.classList.add('opacity-100', 'translate-y-0');
      }
    });
  }, { threshold: 0.1 });

  document.querySelectorAll('.reveal-services').forEach(item => observer.observe(item));
</script>
