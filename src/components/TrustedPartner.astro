---

<section class="bg-[#050505] text-white relative border-t border-gray-900 border-b pb-32 overflow-hidden" id="trusted-partner-section">
  <div class="absolute inset-0 opacity-[0.03] pointer-events-none" 
    style="background-image: linear-gradient(#fff 1px, transparent 1px), linear-gradient(90deg, #fff 1px, transparent 1px); background-size: 60px 60px;">
  </div>

  <div class="max-w-7xl mx-auto px-6 md:px-12 relative z-10 flex flex-col lg:flex-row gap-16 lg:gap-32 pt-24 lg:pt-40">
    <div class="lg:w-5/12 shrink-0">
      <div class="sticky top-32 lg:top-40 pt-10">
        <div class="flex items-center gap-4 mb-6">
          <span class="text-[10px] font-bold tracking-[0.4em] uppercase text-[#FF0000]">Institutional Trust</span>
        </div>
        <h2 class="text-3xl md:text-4xl lg:text-[46px] font-black tracking-tight text-white leading-[1.05] mb-12">
          Why General Tech Services is the Most Trusted <span class="text-[#FF0000]">ISO 17025 Calibration Laboratory</span> and Industrial Equipment Supplier UAE
        </h2>
      </div>
    </div>

    <div class="lg:w-7/12 flex flex-col pt-10 pb-[10vh]">
      {reasons.map((reason, index) => (
        <div class="py-24 lg:py-32 border-b border-white/5 last:border-none relative group reveal-chapter transition-all duration-700 opacity-20 scale-[0.98] translate-y-8" data-index={index}>
          <div class="flex flex-col md:flex-row gap-8 lg:gap-12 items-start relative z-10 w-full">
            <div class="font-mono text-6xl md:text-7xl font-black shrink-0 tracking-tighter leading-none text-white/10 chapter-number transition-colors duration-500">
              {(index + 1).toString().padStart(2, '0')}
            </div>
            <div>
              <h3 class="text-3xl md:text-4xl lg:text-[40px] font-bold tracking-tight text-white mb-6 leading-tight transition-colors duration-500">
                {reason.title}
              </h3>
              <p class="text-gray-400 font-light text-lg md:text-[19px] leading-[1.8]">
                {reason.desc}
              </p>
            </div>
          </div>
          <div class="absolute top-1/2 left-0 w-full h-full max-h-[300px] bg-[#FF0000]/5 rounded-full blur-[120px] -translate-y-1/2 opacity-0 glow-effect transition-opacity duration-700 pointer-events-none"></div>
        </div>
      ))}
    </div>
  </div>
</section>

<script>
  const chapters = document.querySelectorAll('.reveal-chapter');
  
  const observer = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
      if (entry.isIntersecting) {
        entry.target.classList.add('active-chapter');
        entry.target.classList.remove('opacity-20', 'scale-[0.98]', 'translate-y-8');
        entry.target.classList.add('opacity-100', 'scale-100', 'translate-y-0');
        
        const num = entry.target.querySelector('.chapter-number');
        if (num) num.classList.add('text-[#FF0000]');
        
        const glow = entry.target.querySelector('.glow-effect');
        if (glow) glow.classList.add('opacity-100');
      } else {
        // Optional: Re-dim when scrolling away
        if (entry.boundingClientRect.top > 0) { // Only dim if we haven't scrolled past it yet upwards
           entry.target.classList.add('opacity-20', 'scale-[0.98]', 'translate-y-8');
           entry.target.classList.remove('active-chapter', 'opacity-100', 'scale-100', 'translate-y-0');
           
           const num = entry.target.querySelector('.chapter-number');
           if (num) num.classList.remove('text-[#FF0000]');
           
           const glow = entry.target.querySelector('.glow-effect');
           if (glow) glow.classList.remove('opacity-100');
        }
      }
    });
  }, { 
    threshold: 0.5,
    rootMargin: "-10% 0% -10% 0%"
  });

  chapters.forEach(chapter => observer.observe(chapter));
</script>
