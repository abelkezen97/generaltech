---

const posts = [
  {
    date: { month: 'Feb', day: '03' },
    title: 'Industrial Retrofit Solutions: Control Panel, VFD, and Instrumentation Upgrades for UAE Facilities',
    excerpt: 'Retrofitting is one of the most practical ways for facility management teams to improve reliability, safety, and energy performance without the cost of a full systemic replacement.',
    category: 'Admin / Retrofit'
  },
  {
    date: { month: 'Jan', day: '07' },
    title: 'ISO/IEC 17025 Calibration in the UAE: Why It Matters and Why It Is Worth the Premium?',
    excerpt: 'In industrial operations, the smallest measurement error can quietly become a costly problem. ISO/IEC 17025 calibration is a technical assurance system that protects measurement integrity.',
    category: 'Admin / Calibration'
  },
  {
    date: { month: 'Dec', day: '06' },
    title: 'Comprehensive VFD, HMI, Instrumentation & Automation Repairs by General Tech Services',
    excerpt: 'Across the UAE’s industrial sector, downtime is one of the biggest challenges. We offer reliable, experienced support backed by warranty for critical control equipment.',
    category: 'Admin / Repair'
  }
];
---

<section class="py-32 px-6 md:px-12 bg-gray-50/50 border-t border-gray-100">
  <div class="max-w-7xl mx-auto">
    <div class="flex flex-col md:flex-row justify-between items-end mb-20 gap-12">
      <div class="max-w-2xl">
        <div class="flex items-center gap-3 mb-8">
          <div class="w-8 h-[2px] bg-[#FF0000]" />
          <span class="text-[11px] font-bold tracking-[0.25em] uppercase text-[#FF0000]">
            Insights & Updates
          </span>
        </div>
        <h2 class="text-5xl lg:text-[72px] font-black tracking-tight text-general-black leading-[0.95]">
          From the <br />
          <span class="text-[#FF0000] italic font-medium">Blog.</span>
        </h2>
      </div>
      <a href="#" class="inline-flex items-center gap-2 text-general-black font-semibold hover:text-general-red transition-colors group uppercase tracking-widest text-sm">
        View All Articles
      </a>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
      {posts.map(post => (
        <a href="#" class="group bg-white p-8 border border-gray-100 rounded-2xl hover:border-general-black transition-colors flex flex-col items-start h-full">
          <div class="flex gap-4 items-center w-full mb-8 pb-8 border-b border-gray-100">
            <div class="flex flex-col items-center justify-center bg-gray-50 px-4 py-2 text-center group-hover:bg-general-black group-hover:text-white transition-colors">
              <span class="text-2xl font-bold leading-none">{post.date.day}</span>
              <span class="text-xs font-semibold uppercase tracking-widest mt-1">{post.date.month}</span>
            </div>
            <span class="text-xs tracking-widest uppercase text-gray-400 font-medium ml-auto">
              {post.category}
            </span>
          </div>
          
          <h3 class="text-xl font-bold tracking-tight mb-4 group-hover:text-general-red transition-colors line-clamp-3">
            {post.title}
          </h3>
          <p class="text-gray-500 font-light leading-relaxed mb-8 line-clamp-3">
            {post.excerpt}
          </p>
          
          <div class="mt-auto flex items-center justify-between w-full pt-4">
            <span class="text-sm font-semibold tracking-wide text-general-black group-hover:text-general-red transition-colors">Read Article</span>
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-gray-300 group-hover:text-general-red transition-colors"><path d="M7 7h10v10"/><path d="M7 17 17 7"/></svg>
          </div>
        </a>
      ))}
    </div>
  </div>
</section>
